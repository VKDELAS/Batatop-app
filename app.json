{
  "expo": {
    "name": "Batata Top",
    "slug": "batata-top",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "batatatop",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7ED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.batatatop.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#F97316"
      },
      "package": "com.batatatop.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#1A1A1A",
          "sounds": [
            "./assets/sounds/new_order.mp3"
          ],
          "defaultChannel": "new-orders"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
